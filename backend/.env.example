PORT=8080
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=milegame
GIN_MODE=debug

# Google Drive Backup (MVP)
# Feature flag - set to true to enable Drive backup UI and enqueuing
ENABLE_GOOGLE_DRIVE_BACKUP=false

# GCP OAuth 2.0 credentials (project: event-hub-492622)
# Create via: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth redirect URI - update for prod
GOOGLE_REDIRECT_URI=http://localhost:8081/api/admin/drive/callback

# AES-256-GCM encryption key for OAuth tokens at rest (32 bytes)
# Generate with: openssl rand -32 | base64
DRIVE_ENCRYPTION_KEY=
